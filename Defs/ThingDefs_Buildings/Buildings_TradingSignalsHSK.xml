<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<!-- Tribal signal campfire: calls Neolithic caravans, burns and is destroyed on arrival -->
	<ThingDef ParentName="BuildingBase">
		<defName>TribalSignalCampfire</defName>
		<label>tribal signal fire</label>
		<description>A large signal fire. Light it to raise a smoke column visible to nearby tribal allies — a trading caravan from a Neolithic faction may answer. The fire burns until the caravan arrives, then the campfire is consumed. Costs 200 silver on activation.</description>
		<thingClass>TradingSignalsHSK.Building_TradingSignalsHSK</thingClass>
		<graphicData>
			<texPath>Things/Building/Misc/Campfire</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawRotated>false</drawRotated>
			<allowFlip>false</allowFlip>
			<damageData>
				<rect>(0.2,0,0.6,0.1)</rect>
			</damageData>
		</graphicData>
		<uiIconPath>TradingSignalsHSK/SignalFire</uiIconPath>
		<useHitPoints>false</useHitPoints>
		<statBases>
			<WorkToBuild>350</WorkToBuild>
			<Flammability>0</Flammability>
			<Beauty>-2</Beauty>
		</statBases>
		<size>(1,1)</size>
		<passability>PassThroughOnly</passability>
		<pathCost>42</pathCost>
		<fillPercent>0.1</fillPercent>
		<canOverlapZones>false</canOverlapZones>
		<constructEffect>ConstructDirt</constructEffect>
		<building>
			<ai_chillDestination>false</ai_chillDestination>
		</building>
		<tickerType>Normal</tickerType>
		<costList>
			<WoodLog>70</WoodLog>
		</costList>
		<comps>
			<li Class="CompProperties_Glower">
				<glowRadius>8</glowRadius>
				<glowColor>(252,187,113,0)</glowColor>
			</li>
			<li Class="TradingSignalsHSK.CompProperties_TradeSignal">
				<cooldownTicks>2100000</cooldownTicks>
				<silverCost>200</silverCost>
				<arrivalDelayTicks>120000</arrivalDelayTicks>
				<targetTechLevel>Neolithic</targetTechLevel>
				<destroyOnUse>true</destroyOnUse>
				<disableAtTechLevel>Industrial</disableAtTechLevel>
				<cooldownKey>tradeSignal</cooldownKey>
				<commandLabelKey>TribalSignal_CommandLabel</commandLabelKey>
				<commandDescKey>TribalSignal_CommandDesc</commandDescKey>
				<scheduledKey>TribalSignal_Scheduled</scheduledKey>
				<noFactionKey>TribalSignal_NoFaction</noFactionKey>
				<activeKey>TribalSignal_Burning</activeKey>
				<doneKey>TribalSignal_BurnedOut</doneKey>
			</li>
		</comps>
		<researchPrerequisites>
			<li>SignalFires</li>
		</researchPrerequisites>
		<designationCategory>Misc</designationCategory>
	</ThingDef>

	<!-- Medieval dovecote: calls Medieval caravans, reusable -->
	<ThingDef ParentName="BuildingBase">
		<defName>MedievalDovecote</defName>
		<label>dovecote</label>
		<description>A small pigeon house. Send a carrier pigeon to request a trader caravan from a Medieval faction. The dovecote is reusable — after the caravan arrives it can be used again after a cooldown. Costs 200 silver on activation.</description>
		<thingClass>TradingSignalsHSK.Building_TradingSignalsHSK</thingClass>
		<graphicData>
			<texPath>TradingSignalsHSK/Dovecote</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>(2,2)</drawSize>
			<drawRotated>false</drawRotated>
			<allowFlip>false</allowFlip>
		</graphicData>
		<uiIconPath>TradingSignalsHSK/Dovecote</uiIconPath>
		<useHitPoints>true</useHitPoints>
		<statBases>
			<WorkToBuild>800</WorkToBuild>
			<MaxHitPoints>180</MaxHitPoints>
			<Flammability>0.5</Flammability>
			<DeteriorationRate>0</DeteriorationRate>
			<Beauty>1</Beauty>
		</statBases>
		<size>(2,2)</size>
		<passability>PassThroughOnly</passability>
		<pathCost>42</pathCost>
		<fillPercent>0.25</fillPercent>
		<canOverlapZones>false</canOverlapZones>
		<constructEffect>ConstructWood</constructEffect>
		<building>
			<ai_chillDestination>false</ai_chillDestination>
		</building>
		<tickerType>Normal</tickerType>
		<costList>
			<WoodLog>70</WoodLog>
			<ComponentMedieval>4</ComponentMedieval>
		</costList>
		<comps>
			<li Class="TradingSignalsHSK.CompProperties_TradeSignal">
				<cooldownTicks>1320000</cooldownTicks>
				<silverCost>200</silverCost>
				<arrivalDelayTicks>120000</arrivalDelayTicks>
				<targetTechLevel>Medieval</targetTechLevel>
				<fallbackTechLevel>Neolithic</fallbackTechLevel>
				<destroyOnUse>false</destroyOnUse>
				<spawnBirdsOnUse>true</spawnBirdsOnUse>
				<birdCount>2</birdCount>
				<birdKindDef>Crow</birdKindDef>
				<disableAtResearch>Oil_Industry_C1</disableAtResearch>
				<cooldownKey>tradeSignal</cooldownKey>
				<commandLabelKey>MedievalSignal_CommandLabel</commandLabelKey>
				<commandDescKey>MedievalSignal_CommandDesc</commandDescKey>
				<scheduledKey>MedievalSignal_Scheduled</scheduledKey>
				<noFactionKey>MedievalSignal_NoFaction</noFactionKey>
				<activeKey>MedievalSignal_Active</activeKey>
				<doneKey>MedievalSignal_Done</doneKey>
			</li>
		</comps>
		<researchPrerequisites>
			<li>CarrierPigeons</li>
		</researchPrerequisites>
		<designationCategory>Misc</designationCategory>
	</ThingDef>
</Defs>
